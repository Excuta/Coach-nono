# Copy this to .env and fill in your values.
# .env is gitignored — never commit it.

# --- Database ---
DATABASE_URL=postgresql://coach:coach@db:5432/coach

# --- File paths (inside containers; host bind-mount is ./data -> /data) ---
DATA_DIR=/data

# --- GPU / LLM coach (only needed with --profile gpu) ---
OLLAMA_URL=http://coach-llm:11434
COACH_MODEL=qwen2.5:7b-instruct-q4_K_M

# --- Optional tuning ---
# WORKER_LEASE_MINUTES=5      # stale lease reset threshold
# LOG_LEVEL=INFO
