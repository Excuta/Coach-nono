# Copy this to .env and fill in your values.
# .env is gitignored — never commit it.

# --- Database ---
DATABASE_URL=postgresql://coach:coach@db:5432/coach

# --- File paths (inside containers; host bind-mount is ./data -> /data) ---
DATA_DIR=/data

# --- Coach persona ---
COACH_NAME=Coach Nono
# Override the full system-prompt preamble if you want to experiment with the voice:
# COACH_PERSONA=You are Coach Nono, an expert sim-racing coach ...

# --- GPU / LLM coach (only needed with --profile gpu) ---
OLLAMA_URL=http://coach-llm:11434
COACH_MODEL=qwen2.5:7b-instruct-q4_K_M

# --- TTS voice output (Phase E+, optional) ---
# Uses Nono's real recorded voice via XTTS v2 zero-shot cloning.
# COACH_TTS=xtts
# TTS_VOICE_REF=/data/reference/nono_voice.wav   # path to a clean ~10s WAV of her voice

# --- Optional tuning ---
# WORKER_LEASE_MINUTES=5      # stale lease reset threshold
# LOG_LEVEL=INFO
