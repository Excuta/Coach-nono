# Copy this to .env and fill in your values.
# .env is gitignored — never commit it.

# --- Database (Docker) ---
POSTGRES_USER=coach
POSTGRES_PASSWORD=coach
POSTGRES_DB=coach
DATABASE_URL=postgresql://coach:coach@db:5432/coach

# --- File paths (inside containers; host bind-mount is ./data -> /data) ---
DATA_DIR=/data

# --- Coach persona ---
COACH_NAME=Coach Nono
# Override the full system-prompt preamble if you want to experiment with the voice:
# COACH_PERSONA=You are Coach Nono, an expert sim-racing coach ...

# --- Capture agent (runs on the Windows host, not in Docker) ---
# Set to true to record per-lap car XYZ world coordinates in data/coords/<session_id>/.
# Off by default. Useful for a future step that fits or imports track geometry.
# CAPTURE_COORDS=true

# --- Analysis engine ---
# Major ACC version used to scope corner baselines. Update when ACC ships a major physics update.
# Laps from different major versions are never mixed into the same baseline.
GAME_VERSION_MAJOR=1.10

# --- Optional tuning ---
# WORKER_LEASE_MINUTES=5      # stale lease reset threshold
# LOG_LEVEL=INFO
